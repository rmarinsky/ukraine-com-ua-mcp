# Required: API token from https://adm.tools/user/api/
ADM_TOOLS_TOKEN=your_token_here

# Optional: override base URL (default: https://adm.tools)
# ADM_TOOLS_BASE_URL=https://adm.tools

# Optional: per-request timeout in ms (default: 15000)
# ADM_TOOLS_TIMEOUT_MS=15000

# Optional: max retry attempts for 5xx and 429 (default: 3)
# ADM_TOOLS_MAX_RETRIES=3

# Optional: cache TTL for list_domains in ms (default: 3600000 = 1 hour)
# ADM_TOOLS_DOMAIN_CACHE_TTL_MS=3600000

# Optional: enable request log file (token is always redacted)
# ADM_TOOLS_LOG_FILE=/tmp/admtools-requests.log

# Optional: enable destructive write tools (default: true)
# Set to false to expose only read-only tools (useful for safer environments)
# ADM_TOOLS_ENABLE_WRITE_TOOLS=true

# Optional: directory where DNS zone snapshots are stored before mutations
# (default: ./dns-backups, relative to the MCP server cwd)
# ADM_TOOLS_BACKUP_DIR=./dns-backups

# Optional: how long a backup_id remains valid in ms (default: 600000 = 10 minutes)
# ADM_TOOLS_BACKUP_MAX_AGE_MS=600000

# Optional: require backup_id on every write tool (default: true).
# Set to false ONLY for CI/automation that can't run backup_dns_zone first.
# ADM_TOOLS_REQUIRE_BACKUP=true
